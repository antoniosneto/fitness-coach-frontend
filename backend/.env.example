# PostgreSQL – para uso com docker compose (raiz do projeto: docker compose up -d)
# Credenciais padrão do container: user=fitness, password=fitness_local, db=fitness_coach
DATABASE_URL="postgresql://fitness:fitness_local@localhost:5432/fitness_coach?schema=public"

# JWT
# JWT_SECRET=  (em dev o código usa fallback; em produção defina um secret forte)
# JWT_EXPIRES_IN=7d
