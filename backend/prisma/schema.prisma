// Schema Prisma – Épico 1: Autenticação, Onboarding e Motor de Metas
// Ref: refinamento-tecnico-001-auth-onboarding-metas.md (seção 2)
// PRD: prd-001-auth-onboarding-metas.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// TENANT – Entidade raiz para isolamento multi-tenant (whitelabel)
// ---------------------------------------------------------------------------
model Tenant {
  tenantId String   @id @default(uuid()) @map("tenant_id")
  name     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users      User[]
  weeklyPlans WeeklyPlan[]
  foods      Food[]
}

// ---------------------------------------------------------------------------
// USER – Usuário final; soft delete; email único por tenant
// ---------------------------------------------------------------------------
model User {
  userId      String    @id @default(uuid()) @map("user_id")
  tenantId    String    @map("tenant_id")
  email       String
  passwordHash String   @map("password_hash")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [tenantId], onDelete: Restrict)
  profile  UserProfile?
  goals    BodyCompositionGoal[]
  weeklyPlans WeeklyPlan[]
  authSessions AuthSession[]
  passwordResetTokens PasswordResetToken[]
  trainingPreference TrainingPreference?

  @@unique([tenantId, email])
  @@map("users")
}

// ---------------------------------------------------------------------------
// USER_PROFILE – Perfil biométrico e dados básicos; 1:1 com User
// ---------------------------------------------------------------------------
model UserProfile {
  userProfileId       String    @id @default(uuid()) @map("user_profile_id")
  userId              String    @unique @map("user_id")
  name                String
  sex                 String    // enum: male | female | other
  birthDate           DateTime  @map("birth_date") @db.Date
  weightKg            Float?    @map("weight_kg")
  heightCm            Float     @map("height_cm")
  bodyFatPercentage   Float?    @map("body_fat_percentage")
  bodyFatVisualId     String?   @map("body_fat_visual_id")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Restrict)
  @@map("user_profiles")
}

// ---------------------------------------------------------------------------
// BODY_COMPOSITION_GOAL – Meta de composição corporal; soft delete
// ---------------------------------------------------------------------------
model BodyCompositionGoal {
  goalId                 String    @id @default(uuid()) @map("goal_id")
  userId                 String    @map("user_id")
  currentWeightKg        Float     @map("current_weight_kg")
  currentBodyFatPercent  Float     @map("current_body_fat_percent")
  targetWeightKg         Float     @map("target_weight_kg")
  targetBodyFatPercent   Float     @map("target_body_fat_percent")
  monthsToTarget         Int       @map("months_to_target") // >= 1
  intensity              String    // enum: light | medium | high
  deletedAt              DateTime? @map("deleted_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Restrict)
  @@map("body_composition_goals")
}

// ---------------------------------------------------------------------------
// WEEKLY_PLAN – Plano semanal; soft delete
// ---------------------------------------------------------------------------
model WeeklyPlan {
  weeklyPlanId String    @id @default(uuid()) @map("weekly_plan_id")
  userId       String    @map("user_id")
  tenantId     String    @map("tenant_id")
  startDate    DateTime  @map("start_date") @db.Date
  endDate      DateTime  @map("end_date") @db.Date
  summaryJson  Json?     @map("summary_json")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [userId], onDelete: Restrict)
  tenant Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Restrict)
  @@map("weekly_plans")
}

// ---------------------------------------------------------------------------
// FOOD (TACO) – Alimentos e composição nutricional; seed por tenant
// ---------------------------------------------------------------------------
model Food {
  foodId     String   @id @default(uuid()) @map("food_id")
  tenantId   String   @map("tenant_id")
  description String
  kcal       Float
  proteinG   Float    @map("protein_g")
  carbG      Float    @map("carb_g")
  fatG       Float    @map("fat_g")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Restrict)
  @@index([tenantId, description])
  @@map("foods")
}

// ---------------------------------------------------------------------------
// AUTH_SESSION – Auditoria de sessões (JWT stateless; opcional)
// ---------------------------------------------------------------------------
model AuthSession {
  sessionId String    @id @default(uuid()) @map("session_id")
  userId    String    @map("user_id")
  tenantId  String    @map("tenant_id")
  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Restrict)
  @@map("auth_sessions")
}

// ---------------------------------------------------------------------------
// PASSWORD_RESET_TOKEN – Token temporário para recuperação de senha (REQ-AUTH-003)
// ---------------------------------------------------------------------------
model PasswordResetToken {
  tokenId   String    @id @default(uuid()) @map("token_id")
  userId    String    @map("user_id")
  tenantId  String    @map("tenant_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Restrict)
  @@map("password_reset_tokens")
}

// ---------------------------------------------------------------------------
// TRAINING_PREFERENCE – Preferências de treino (DD-ENT-TRAININGPREFERENCE); 1:1 User
// ---------------------------------------------------------------------------
model TrainingPreference {
  trainingPreferenceId String   @id @default(uuid()) @map("training_preference_id")
  userId               String   @unique @map("user_id")
  tenantId             String   @map("tenant_id")
  machinesOnly         Boolean  @default(true) @map("machines_only")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Restrict)
  @@map("training_preferences")
}
